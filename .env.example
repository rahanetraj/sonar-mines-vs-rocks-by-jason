# Copier ce fichier en .env et remplir les valeurs réelles
# NE JAMAIS committer .env dans git

# MLflow
MLFLOW_TRACKING_URI=./mlruns
MLFLOW_EXPERIMENT_NAME=sonar-classification

# AWS (pour le déploiement ECR/ECS via CI/CD)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=eu-west-1
ECR_REPOSITORY=sonar-api
ECS_CLUSTER=sonar-cluster
ECS_SERVICE=sonar-api-service
